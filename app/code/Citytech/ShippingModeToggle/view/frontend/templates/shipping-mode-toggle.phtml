<?php
/**
 * Hyvä checkout shipping mode toggle.
 *
 * Adds a small Alpine-powered toggle above Shipping Methods:
 * - Home Delivery
 * - Pickup
 *
 * Behavior:
 * - Pickup: show only pickup methods and hide shipping address section.
 * - Home Delivery: show non-pickup methods and show shipping address section.
 */
?>
<script>
    (() => {
        if (!document.body.classList.contains('checkout-index-index')) {
            return;
        }

        const PICKUP_KEYWORDS = ['pickup', 'pick up', 'pick-in-store', 'pick in store', 'collect', 'click & collect'];

        window.shippingModeToggleComponent = () => ({
            mode: 'home',

            setMode(nextMode) {
                this.mode = nextMode;
                applyMode(nextMode);
            },

            buttonClass(buttonMode) {
                const isActive = this.mode === buttonMode;

                return isActive
                    ? 'bg-blue-600 border-blue-600 text-white shadow-sm'
                    : 'bg-white border-slate-300 text-slate-700 hover:border-blue-500 hover:text-blue-600';
            },
        });

        const findShippingTitle = () => {
            const headings = Array.from(document.querySelectorAll('h1, h2, h3, legend, .step-title'));

            return headings.find((heading) => /shipping methods?/i.test(heading.textContent || '')) || null;
        };

        const getAddressContainer = () => {
            const candidates = [
                '#shipping-new-address-form',
                '#shipping',
                '[data-role="shipping-address-form"]',
                '.shipping-address',
                '.checkout-shipping-address',
            ];

            for (const selector of candidates) {
                const element = document.querySelector(selector);
                if (element) {
                    return element;
                }
            }

            return null;
        };

        const getMethodRows = () => {
            const rows = [];
            const radios = document.querySelectorAll('input[type="radio"][name*="shipping"], input[type="radio"][value*="_"]');

            radios.forEach((radio) => {
                const label = radio.id ? document.querySelector(`label[for="${radio.id}"]`) : null;
                const row = radio.closest('tr, li, .field, .method, .shipping-method-item, .col')
                    || label?.closest('tr, li, .field, .method, .shipping-method-item, .col');

                if (!row) {
                    return;
                }

                const methodText = `${radio.value} ${label ? label.textContent : ''} ${row.textContent}`.toLowerCase();
                const isPickup = PICKUP_KEYWORDS.some((keyword) => methodText.includes(keyword));

                rows.push({ radio, row, isPickup });
            });

            return rows;
        };

        const applyMode = (mode) => {
            const addressContainer = getAddressContainer();
            const methodRows = getMethodRows();

            methodRows.forEach(({ row, radio, isPickup }) => {
                const shouldShow = mode === 'pickup' ? isPickup : !isPickup;
                row.style.display = shouldShow ? '' : 'none';

                if (!shouldShow && radio.checked) {
                    radio.checked = false;
                    radio.dispatchEvent(new Event('change', { bubbles: true }));
                }
            });

            const firstVisible = methodRows.find(({ row }) => row.style.display !== 'none');
            if (firstVisible && !firstVisible.radio.checked) {
                firstVisible.radio.checked = true;
                firstVisible.radio.dispatchEvent(new Event('change', { bubbles: true }));
            }

            if (addressContainer) {
                addressContainer.style.display = mode === 'pickup' ? 'none' : '';
            }
        };

        const buildToggleMarkup = () => {
            const wrapper = document.createElement('div');
            wrapper.id = 'shipping-mode-toggle';
            wrapper.className = 'shipping-mode-toggle mt-3 mb-5';
            wrapper.innerHTML = `
                <div class="rounded-xl border border-slate-200 bg-white p-4" x-data="shippingModeToggleComponent()" x-init="setMode('home')">
                    <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-slate-500">Delivery type</p>
                    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                        <button type="button"
                                @click="setMode('home')"
                                :class="buttonClass('home')"
                                class="inline-flex items-center justify-center rounded-lg border px-4 py-3 text-sm font-semibold transition">
                            Home Delivery
                        </button>
                        <button type="button"
                                @click="setMode('pickup')"
                                :class="buttonClass('pickup')"
                                class="inline-flex items-center justify-center rounded-lg border px-4 py-3 text-sm font-semibold transition">
                            Pickup
                        </button>
                    </div>
                </div>
            `;

            return wrapper;
        };

        const init = () => {
            const shippingTitle = findShippingTitle();

            if (!shippingTitle || document.getElementById('shipping-mode-toggle')) {
                return;
            }

            const toggle = buildToggleMarkup();
            shippingTitle.parentNode.insertBefore(toggle, shippingTitle.nextSibling);

            if (window.Alpine?.initTree) {
                window.Alpine.initTree(toggle);
            } else {
                applyMode('home');
            }
        };

        document.addEventListener('DOMContentLoaded', init);

        const observer = new MutationObserver(init);
        observer.observe(document.body, { childList: true, subtree: true });
    })();
</script>
